  output ENCLK;
  wire   net624, net627;

  AND2X2 main_gate ( .A(net627), .B(CLK), .Y(ENCLK) );
  TLATNX1 latch ( .D(net624), .GN(CLK), .Q(net627) );
  OR2X2 test_or ( .A(EN), .B(TE), .Y(net624) );
endmodule


