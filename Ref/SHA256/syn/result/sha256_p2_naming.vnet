module SNPS_CLOCK_GATE_HIGH_sha256_axir_1 ( CLK, EN, ENCLK, TE );
  input CLK, EN, TE;
  output ENCLK;
  wire   net624, net627;

  TLATNX1 latch ( .D(net624), .GN(CLK), .Q(net627) );
  AND2X1 main_gate ( .A(net627), .B(CLK), .Y(ENCLK) );
  OR2X1 test_or ( .A(EN), .B(TE), .Y(net624) );
endmodule


module SNPS_CLOCK_GATE_HIGH_sha256_axir_2 ( CLK, EN, ENCLK, TE );
