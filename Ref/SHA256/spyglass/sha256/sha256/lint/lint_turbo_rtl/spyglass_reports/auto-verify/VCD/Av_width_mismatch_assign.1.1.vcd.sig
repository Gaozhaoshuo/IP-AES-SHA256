verification_cycle
sha256.u_sha256_axir.nxt_blk_len
wf_signal_group -name "Data Path Net nxt_blk_len" -signals {sha256.u_sha256_axir.nxt_blk_len}
sha256.clk
wf_signal_group -name "Clock Net clk" -signals {sha256.clk}
sha256.u_sha256_axir.rtlc_N259
wf_signal_group -name "Internal Enable Net rtlc_N259" -signals {sha256.u_sha256_axir.rtlc_N259}
